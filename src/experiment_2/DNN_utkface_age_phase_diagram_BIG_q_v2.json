{
  "architecture": {
    "model_name": "dnn",
    "input_dim": 12288,
    "hidden_dims": [256, 64, 16],
    "output_dim": 1,
    "activation": "relu",
    "bias": true
  },
  "dataset": {
    "name": "UTKFace",
    "root": "dataset/UTKFace",
    "image_size": 64,
    "train_fraction": 0.8,
    "split_seed": 12345,
    "max_samples": 20000,
    "num_workers": 4
  },
  "seeds": [1,2,3,4],
  "grid": {
    "optimizer": ["sgd"],
    "grad_clip_norm": [10.0],
    "batch_size": [128],
    "epochs": [300],
    "momentum": [0.0],
    "weight_decay": [0.0],
    "eval_epochs": [[1, 2, 5, 10, 15, 20, 50, 70, 100, 130, 160, 200, 250, 300]]
  },
  "coupled_grid": [
    {"lr": 1,        "inv_sigma_w": 0.03125},
    {"lr": 1,        "inv_sigma_w": 2},
    {"lr": 1,        "inv_sigma_w": 32},
    {"lr": 0.5,      "inv_sigma_w": 0.03125},
    {"lr": 0.5,      "inv_sigma_w": 2},
    {"lr": 0.5,      "inv_sigma_w": 32},
    {"lr": 0.25,     "inv_sigma_w": 0.03125},
    {"lr": 0.25,     "inv_sigma_w": 2},
    {"lr": 0.25,     "inv_sigma_w": 32}
  ]
}