# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*.so

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Virtual environments
# -----------------------------
.venv/
venv/
env/
myenv/
conda-env/
*.egg-info/

# -----------------------------
# Logs
# -----------------------------
logs/
pbs_logs/
*.log
*.out
*.err

# -----------------------------
# Raw datasets and local data
# Ignore all raw data
# -----------------------------
data/
datasets/
dataset/
raw_data/
downloads/
tmp/
cache/
*.txt
/results/
/data/
/pbs_logs/
/oe/
/__pycache__/
*.pyc
*.pyo

# -----------------------------
# Experiment run outputs
# Ignore per-run raw outputs
# -----------------------------
results/
runs/
outputs/

# -----------------------------
# Keep only collected results
# -----------------------------
!collected_results/
!collected_results/*.pkl
!collected_results/*.csv
!collected_results/*.json

# -----------------------------
# Optional: keep a placeholder
# if you want empty folders tracked
# -----------------------------
!collected_results/.gitkeep